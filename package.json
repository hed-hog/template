{
  "name": "hedhog",
  "version": "0.0.5",
  "private": true,
  "description": "",
  "author": "HedHog",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "prod": "turbo run prod",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "security": "pnpm audit --audit-level=high",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "init:env": "pnpm exec ts-node ./scripts/init-env.ts",
    "encrypt:integration-secrets": "pnpm exec ts-node ./scripts/encrypt-integration-secrets.ts",
    "patch": "pnpm exec ts-node ./scripts/patch.ts",
    "clean": "node ./scripts/clean",
    "postinstall": "pnpm run init:env",
    "db:update": "pnpm --filter @hed-hog/api-prisma prisma:generate && pnpm --filter api prisma:update",
    "build:libs": "pnpm -r --if-present --filter \"./libraries/*\" --filter \"./packages/*\" run build",
    "start:admin": "node ./scripts/clean-next-cache.js admin && pnpm run db:update && pnpm run build:libs && pnpm -r --filter \"admin\" --filter \"api\" dev",
    "start:admin:worker": "node ./scripts/clean-next-cache.js admin && pnpm run db:update && pnpm run build:libs && node ./scripts/start-admin-with-worker.mjs",
    "start:api": "node ./scripts/clean-next-cache.js api && pnpm run db:update && pnpm run build:libs && pnpm -r --filter \"api\" dev",
    "create:types": "pnpm exec ts-node ./scripts/create-types.ts",
    "postcreate:types": "pnpm -r --filter types build",
    "sync:libs:versions": "hedhog dev sync-publish",
    "promote:production": "node ./scripts/promote-production.js",
    "production": "node ./scripts/promote-production.js",
    "production:core": "node ./scripts/promote-production.js api,admin",
    "production:api": "node ./scripts/promote-production.js api",
    "production:admin": "node ./scripts/promote-production.js admin",
    "sync:changed-files": "pnpm exec ts-node ./scripts/sync-changed-files.ts"
  },
  "devDependencies": {
    "@hed-hog/eslint-config": "workspace:*",
    "@hed-hog/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "mysql2": "3.14.1",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "prisma": "6.18.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "libraries/*"
  ],
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "react-native-draggable-flatlist>react": "19.1.0",
      "validator": ">=13.15.22",
      "glob": ">=11.1.0",
      "@jest/reporters>glob": "^8.1.0",
      "jws": ">=4.0.1",
      "js-yaml": ">=4.1.1",
      "body-parser": ">=2.2.1",
      "tmp": ">=0.2.4",
      "jsonwebtoken": ">=9.0.2",
      "@smithy/core": "3.24.6",
      "@smithy/types": "4.14.3",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
      "shell-quote@>=1.1.0 <=1.8.3": ">=1.8.4",
      "multer@>=2.0.0-alpha.1 <2.2.0": ">=2.2.0",
      "tar@<=7.5.10": ">=7.5.11",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "undici@<6.27.0": ">=6.27.0",
      "postcss@<8.5.10": ">=8.5.10",
      "@nestjs/core@<=11.1.17": ">=11.1.18 <12",
      "next-intl@<=4.9.1": ">=4.9.2 <5",
      "fast-xml-parser@<5.7.0": ">=5.7.0 <6",
      "uuid@<11.1.1": ">=11.1.1 <12",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "defu@<=6.1.4": ">=6.1.5",
      "hono@<4.12.25": ">=4.12.25",
      "@tootallnate/once@<2.0.1": ">=2.0.1",
      "dompurify@<=3.4.10": ">=3.4.11",
      "axios@>=1.0.0 <1.16.0": ">=1.16.0 <2"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@parcel/watcher",
      "@swc/core",
      "canvas",
      "core-js",
      "core-js-pure",
      "electron",
      "esbuild",
      "ffmpeg-static",
      "ffprobe-static",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "argon2",
      "bcrypt"
    ]
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.13",
    "@prisma/client": "6.18.0",
    "axios": "^1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns": "^3.6.0",
    "express": "^4.22.1",
    "png-to-ico": "^2.1.8",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0"
  }
}
