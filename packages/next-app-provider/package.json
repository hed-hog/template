{
  "name": "@hed-hog/next-app-provider",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm run clean && pnpm --dir ../.. exec ts-node ./scripts/build-dependencies.ts packages/next-app-provider",
    "build": "tsc --project ./tsconfig.json",
    "predev": "pnpm run clean",
    "dev": "tsc --project ./tsconfig.json --watch",
    "clean": "rimraf dist",
    "patch": "pnpm exec ts-node ../../scripts/patch.ts packages/api-locale",
    "prod": "pnpm run patch && pnpm run build && pnpm publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.38.0",
    "next": "^16.0.8",
    "rimraf": "^6.1.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@hed-hog/api-types": "workspace:*",
    "@tanstack/react-query": "^5.90.6",
    "axios": "^1.13.0",
    "js-base64": "^3.7.8",
    "react": "^19.2.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "usehooks-ts": "^3.1.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
