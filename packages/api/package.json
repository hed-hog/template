{
  "name": "@hed-hog/api",
  "version": "0.0.8",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "_dev": "pnpm build --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "prebuild": "pnpm --dir ../.. exec ts-node ./scripts/build-dependencies.ts packages/api",
    "build": "tsc --project tsconfig.production.json",
    "patch": "pnpm exec ts-node ../../scripts/patch.ts packages/api",
    "prod": "pnpm run patch && pnpm run build && pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@hed-hog/api-prisma": "workspace:*",
    "@nestjs/common": "*",
    "@nestjs/mapped-types": "*",
    "typeorm": "^0.3.25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1"
  }
}
