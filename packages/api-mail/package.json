{
  "name": "@hed-hog/api-mail",
  "version": "0.0.9",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "_dev": "pnpm build --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "prebuild": "pnpm --dir ../.. exec ts-node ./scripts/build-dependencies.ts packages/api-mail",
    "build": "tsc --project tsconfig.production.json",
    "patch": "pnpm exec ts-node ../../scripts/patch.ts packages/api-mail",
    "prod": "pnpm run patch && pnpm run build && pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1014.0",
    "@hed-hog/api-prisma": "workspace:*",
    "@nestjs/axios": "*",
    "@nestjs/common": "*",
    "@nestjs/jwt": "*",
    "@nestjs/mapped-types": "*",
    "axios": "*",
    "bcrypt": "^5.1.1",
    "googleapis": "144.0.0",
    "mimemessage": "1.0.5",
    "nodemailer": "^7.0.11",
    "rxjs": "*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  }
}
