{
  "$schema": "https://v2-10-3.turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local", "apps/api/prisma/schema.prisma"],
  "tasks": {
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prod": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {}
  }
}
