# Dependencies (NEVER copy these - they are reinstalled in Docker)
**/node_modules
**/.pnpm-store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs (regenerated during build)
**/.next
**/dist
**/build
**/out
**/.turbo
**/coverage

# Development files
.git
.gitignore
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local
**/.vscode
**/.idea
*.swp
*.swo
*~

# Testing
**/coverage
**/.nyc_output
**/*.spec.ts
**/*.test.ts
**/*.spec.tsx
**/*.test.tsx
**/test
**/tests
**/__tests__
**/*.spec.*
**/*.test.*
**/playwright-report
**/test-results

# Docker
**/Dockerfile
**/.dockerignore
**/docker-compose*.yml
**/docker-compose*.yaml

# Documentation (except critical readmes)
*.md
!README.md

# OS
.DS_Store
**/Thumbs.db
**/desktop.ini

# Misc
**/*.log
**/.cache
**/.vercel

# Scripts that aren't needed
**/build-docker.sh
**/build-docker.ps1

# Storage and generated files
**/storage
**/prisma/.env
**/prisma/migrations

# Keep these critical files (override exclusions above)
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!turbo.json
!tsconfig.json
!**/tsconfig.json
!next.config.ts
!next.config.js
!next.config.mjs
!apps/admin/public/**
!apps/admin/messages/**
