{
  "$schema": "https://json.schemastore.org/tsconfig",
  // This project uses `composite: true` (via shared tsconfig), so every file
  // pulled in by `@hed-hog/*` path aliases must be covered by `include`.
  // Otherwise `nest build` can fail with TS6307.
  "include": [
    "src/**/*.ts",
    "../../packages/api/src/**/*.ts",
    "../../packages/api-healthy/src/**/*.ts",
    "../../packages/api-locale/src/**/*.ts",
    "../../packages/api-mail/src/**/*.ts",
    "../../packages/api-pagination/src/**/*.ts",
    "../../packages/api-prisma/src/**/*.ts",
    "../../packages/api-types/src/**/*.ts",
    "../../libraries/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../libraries/*/src/dashboard/widgets/**/*"
  ],
  "extends": "@hed-hog/typescript-config/library.json",
  "compilerOptions": {
    "rootDir": "../../",
    "baseUrl": "./",
    "paths": {
      "@hed-hog/api": ["../../packages/api/src"],
      "@hed-hog/api/*": ["../../packages/api/src/*"],
      "@hed-hog/api-healthy": ["../../packages/api-healthy/src"],
      "@hed-hog/api-healthy/*": ["../../packages/api-healthy/src/*"],
      "@hed-hog/api-locale": ["../../packages/api-locale/src"],
      "@hed-hog/api-locale/*": ["../../packages/api-locale/src/*"],
      "@hed-hog/api-mail": ["../../packages/api-mail/src"],
      "@hed-hog/api-mail/*": ["../../packages/api-mail/src/*"],
      "@hed-hog/api-pagination": ["../../packages/api-pagination/src"],
      "@hed-hog/api-pagination/*": ["../../packages/api-pagination/src/*"],
      "@hed-hog/api-prisma": ["../../packages/api-prisma/src"],
      "@hed-hog/api-prisma/*": ["../../packages/api-prisma/src/*"],
      "@hed-hog/api-types": ["../../packages/api-types/src"],
      "@hed-hog/api-types/*": ["../../packages/api-types/src/*"],
      "@hed-hog-pro/agent": ["../../libraries/agent/src"],
      "@hed-hog-pro/agent/*": ["../../libraries/agent/src/*"],
      "@hed-hog-pro/address": ["../../libraries/address/src"],
      "@hed-hog-pro/address/*": ["../../libraries/address/src/*"],
      "@hed-hog/billing": ["../../libraries/billing/src"],
      "@hed-hog/billing/*": ["../../libraries/billing/src/*"],
      "@hed-hog/catalog": ["../../libraries/catalog/src"],
      "@hed-hog/catalog/*": ["../../libraries/catalog/src/*"],
      "@hed-hog-pro/campaign": ["../../libraries/campaign/src"],
      "@hed-hog-pro/campaign/*": ["../../libraries/campaign/src/*"],
      "@hed-hog-pro/category": ["../../libraries/category/src"],
      "@hed-hog-pro/category/*": ["../../libraries/category/src/*"],
      "@hed-hog-pro/commerce": ["../../libraries/commerce/src"],
      "@hed-hog-pro/commerce/*": ["../../libraries/commerce/src/*"],
      "@hed-hog-pro/crm": ["../../libraries/crm/src"],
      "@hed-hog-pro/crm/*": ["../../libraries/crm/src/*"],
      "@hed-hog/contact-us": ["../../libraries/contact-us/src"],
      "@hed-hog/contact-us/*": ["../../libraries/contact-us/src/*"],
      "@hed-hog/content": ["../../libraries/content/src"],
      "@hed-hog/content/*": ["../../libraries/content/src/*"],
      "@hed-hog/core": ["../../libraries/core/src"],
      "@hed-hog/core/*": ["../../libraries/core/src/*"],
      "@hed-hog/developer-mode": ["../../libraries/developer-mode/src"],
      "@hed-hog/developer-mode/*": ["../../libraries/developer-mode/src/*"],
      "@hed-hog/faq": ["../../libraries/faq/src"],
      "@hed-hog/faq/*": ["../../libraries/faq/src/*"],
      "@hed-hog-pro/finance": ["../../libraries/finance/src"],
      "@hed-hog-pro/finance/*": ["../../libraries/finance/src/*"],
      "@hed-hog-pro/inbox": ["../../libraries/inbox/src"],
      "@hed-hog-pro/inbox/*": ["../../libraries/inbox/src/*"],
      "@hed-hog-pro/lms": ["../../libraries/lms/src"],
      "@hed-hog-pro/lms/*": ["../../libraries/lms/src/*"],
      "@hed-hog-pro/operations": ["../../libraries/operations/src"],
      "@hed-hog-pro/operations/*": ["../../libraries/operations/src/*"],
      "@hed-hog-pro/queue": ["../../libraries/queue/src"],
      "@hed-hog-pro/queue/*": ["../../libraries/queue/src/*"],
      "@hed-hog-pro/tag": ["../../libraries/tag/src"],
      "@hed-hog-pro/tag/*": ["../../libraries/tag/src/*"],
      "@hed-hog/ticket": ["../../libraries/ticket/src"],
      "@hed-hog/ticket/*": ["../../libraries/ticket/src/*"]
    },
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "allowJs": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "moduleResolution": "node",
    "outDir": "./dist"
  }
}
