generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model access_log {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  ip         String?  @db.VarChar(45)
  user_agent String?
  method     String?  @db.VarChar(10)
  path       String?  @db.VarChar(2048)
  mcp_tool   String?  @db.VarChar(255)
  mcp_prompt String?
  created_at DateTime @default(now())
  user       user?    @relation(fields: [user_id], references: [id])

  @@index([created_at])
  @@index([user_id])
}

model achievement {
  id                                        Int                              @id @default(autoincrement())
  name                                      String                           @db.VarChar(255)
  description                               String?
  icon_file_id                              Int?
  main_image_file_id                        Int?
  type                                      achievement_type_6ee0f922f6_enum @default(custom)
  bitcodes_value                            Int                              @default(0)
  can_receive_multiple_times                Boolean                          @default(false)
  created_at                                DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at                                DateTime                         @default(now()) @db.Timestamptz(6)
  file_achievement_icon_file_idTofile       file?                            @relation("achievement_icon_file_idTofile", fields: [icon_file_id], references: [id], onUpdate: NoAction, map: "file_icon_file_id_fkey")
  file_achievement_main_image_file_idTofile file?                            @relation("achievement_main_image_file_idTofile", fields: [main_image_file_id], references: [id], onUpdate: NoAction, map: "file_main_image_file_id_fkey")

  @@index([name])
  @@index([type])
}

model address {
  id             Int                                  @id @default(autoincrement())
  address_type   address_address_type_1b58dba508_enum
  country_code   String                               @db.VarChar
  state          String                               @db.VarChar
  city           String                               @db.VarChar
  postal_code    String                               @db.VarChar
  line1          String                               @db.VarChar
  line2          String                               @db.VarChar
  is_primary     Boolean                              @default(false)
  created_at     DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at     DateTime                             @default(now()) @db.Timestamptz(6)
  person_address person_address[]
}

model agent {
  id                                                    Int                    @id @default(autoincrement())
  slug                                                  String                 @unique(map: "agent_slug_unique") @db.VarChar(255)
  name                                                  String                 @db.VarChar(180)
  description                                           String?
  type                                                  agent_type_enum        @default(agent)
  mode                                                  agent_mode_enum        @default(sync)
  status                                                agent_status_enum      @default(draft)
  current_version_id                                    Int?
  created_by_id                                         Int?
  updated_by_id                                         Int?
  created_at                                            DateTime               @default(now())
  updated_at                                            DateTime               @default(now())
  user_agent_created_by_idTouser                        user?                  @relation("agent_created_by_idTouser", fields: [created_by_id], references: [id])
  agent_version_agent_current_version_idToagent_version agent_version?         @relation("agent_current_version_idToagent_version", fields: [current_version_id], references: [id], onUpdate: NoAction)
  user_agent_updated_by_idTouser                        user?                  @relation("agent_updated_by_idTouser", fields: [updated_by_id], references: [id])
  agent_run                                             agent_run[]
  agent_secret_binding                                  agent_secret_binding[]
  agent_trigger                                         agent_trigger[]
  agent_variable                                        agent_variable[]
  agent_version_agent_version_agent_idToagent           agent_version[]        @relation("agent_version_agent_idToagent")

  @@index([created_by_id])
  @@index([mode])
  @@index([status])
  @@index([type])
}

model agent_branch_result {
  id                Int                             @id @default(autoincrement())
  barrier_id        Int
  branch_index      Int                             @default(0)
  branch_id         String?                         @db.VarChar(127)
  status            agent_branch_result_status_enum
  output            Json?
  state_patch       Json?
  error             String?
  created_at        DateTime                        @default(now())
  agent_run_barrier agent_run_barrier               @relation(fields: [barrier_id], references: [id], onDelete: Cascade)

  @@unique([barrier_id, branch_index], map: "agent_branch_result_barrier_branch_unique")
  @@index([barrier_id])
}

model agent_checkpoint {
  id             Int             @id @default(autoincrement())
  run_id         Int
  step_id        Int?
  checkpoint_key String          @db.VarChar(255)
  state          Json
  metadata       Json?
  created_at     DateTime        @default(now())
  agent_run      agent_run       @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_run_step agent_run_step? @relation(fields: [step_id], references: [id], onUpdate: NoAction)

  @@unique([run_id, checkpoint_key], map: "agent_checkpoint_run_key_unique")
  @@index([run_id])
  @@index([step_id])
}

model agent_edge {
  id                                               Int                             @id @default(autoincrement())
  agent_version_id                                 Int
  source_node_id                                   Int
  target_node_id                                   Int
  source_handle                                    String?                         @db.VarChar(127)
  target_handle                                    String?                         @db.VarChar(127)
  condition_type                                   agent_edge_condition_type_enum?
  condition_expression                             String?
  priority                                         Int                             @default(0)
  label                                            String?                         @db.VarChar(127)
  config                                           Json?
  created_at                                       DateTime                        @default(now())
  updated_at                                       DateTime                        @default(now())
  agent_version                                    agent_version                   @relation(fields: [agent_version_id], references: [id], onDelete: Cascade)
  agent_node_agent_edge_source_node_idToagent_node agent_node                      @relation("agent_edge_source_node_idToagent_node", fields: [source_node_id], references: [id], onDelete: Cascade)
  agent_node_agent_edge_target_node_idToagent_node agent_node                      @relation("agent_edge_target_node_idToagent_node", fields: [target_node_id], references: [id], onDelete: Cascade)
  agent_run_decision                               agent_run_decision[]
  agent_run_transition                             agent_run_transition[]

  @@index([agent_version_id])
  @@index([condition_type])
  @@index([source_node_id])
  @@index([target_node_id])
}

model agent_human_approval {
  id                                              Int                              @id @default(autoincrement())
  run_id                                          Int
  step_id                                         Int?
  requested_by_id                                 Int?
  assigned_to_id                                  Int?
  status                                          agent_human_approval_status_enum @default(pending)
  title                                           String?                          @db.VarChar(255)
  description                                     String?
  payload                                         Json?
  response                                        Json?
  requested_at                                    DateTime?
  responded_at                                    DateTime?
  expires_at                                      DateTime?
  created_at                                      DateTime                         @default(now())
  updated_at                                      DateTime                         @default(now())
  channel                                         String?                          @db.VarChar(20)
  recipient                                       String?                          @db.VarChar(255)
  webhook_integration_id                          Int?
  user_agent_human_approval_assigned_to_idTouser  user?                            @relation("agent_human_approval_assigned_to_idTouser", fields: [assigned_to_id], references: [id])
  user_agent_human_approval_requested_by_idTouser user?                            @relation("agent_human_approval_requested_by_idTouser", fields: [requested_by_id], references: [id])
  agent_run                                       agent_run                        @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_run_step                                  agent_run_step?                  @relation(fields: [step_id], references: [id], onUpdate: NoAction)
  webhook_integration                             webhook_integration?             @relation(fields: [webhook_integration_id], references: [id])

  @@index([assigned_to_id])
  @@index([expires_at])
  @@index([requested_by_id])
  @@index([run_id])
  @@index([status])
  @@index([step_id])
  @@index([webhook_integration_id])
}

model agent_node {
  id                                                                        Int                    @id @default(autoincrement())
  agent_version_id                                                          Int
  node_key                                                                  String                 @db.VarChar(127)
  type                                                                      String                 @db.VarChar(80)
  name                                                                      String                 @db.VarChar(180)
  description                                                               String?
  config                                                                    Json?
  position_x                                                                Decimal                @default(0) @db.Decimal(12, 2)
  position_y                                                                Decimal                @default(0) @db.Decimal(12, 2)
  input_schema                                                              Json?
  output_schema                                                             Json?
  is_entrypoint                                                             Boolean                @default(false)
  is_terminal                                                               Boolean                @default(false)
  created_at                                                                DateTime               @default(now())
  updated_at                                                                DateTime               @default(now())
  agent_edge_agent_edge_source_node_idToagent_node                          agent_edge[]           @relation("agent_edge_source_node_idToagent_node")
  agent_edge_agent_edge_target_node_idToagent_node                          agent_edge[]           @relation("agent_edge_target_node_idToagent_node")
  agent_version                                                             agent_version          @relation(fields: [agent_version_id], references: [id], onDelete: Cascade)
  agent_run_decision_agent_run_decision_node_idToagent_node                 agent_run_decision[]   @relation("agent_run_decision_node_idToagent_node")
  agent_run_decision_agent_run_decision_selected_target_node_idToagent_node agent_run_decision[]   @relation("agent_run_decision_selected_target_node_idToagent_node")
  agent_run_event                                                           agent_run_event[]
  agent_run_step                                                            agent_run_step[]
  agent_run_transition_agent_run_transition_source_node_idToagent_node      agent_run_transition[] @relation("agent_run_transition_source_node_idToagent_node")
  agent_run_transition_agent_run_transition_target_node_idToagent_node      agent_run_transition[] @relation("agent_run_transition_target_node_idToagent_node")
  agent_secret_binding                                                      agent_secret_binding[]

  @@unique([agent_version_id, node_key], map: "agent_node_version_key_unique")
  @@index([agent_version_id])
  @@index([is_entrypoint])
  @@index([is_terminal])
  @@index([type])
}

model agent_run {
  id                    Int                    @id @default(autoincrement())
  agent_id              Int
  agent_version_id      Int?
  trigger_id            Int?
  status                agent_run_status_enum  @default(queued)
  mode                  agent_run_mode_enum    @default(sync)
  input                 Json?
  output                Json?
  state                 Json?
  error                 String?
  started_at            DateTime?
  finished_at           DateTime?
  duration_ms           Int?
  created_by_id         Int?
  correlation_id        String?                @db.VarChar(127)
  trace_id              String?                @db.VarChar(127)
  total_input_tokens    Int                    @default(0)
  total_output_tokens   Int                    @default(0)
  total_tokens          Int                    @default(0)
  total_estimated_cost  Decimal?               @db.Decimal(12, 6)
  total_actual_cost     Decimal?               @db.Decimal(12, 6)
  currency              String                 @default("USD") @db.Char(3)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @default(now())
  parent_run_id         Int?
  parent_barrier_id     Int?
  step_budget_remaining Int?
  agent_checkpoint      agent_checkpoint[]
  agent_human_approval  agent_human_approval[]
  agent                 agent                  @relation(fields: [agent_id], references: [id], onUpdate: NoAction)
  agent_version         agent_version?         @relation(fields: [agent_version_id], references: [id], onUpdate: NoAction)
  user                  user?                  @relation(fields: [created_by_id], references: [id])
  agent_run             agent_run?             @relation("agent_runToagent_run", fields: [parent_run_id], references: [id])
  other_agent_run       agent_run[]            @relation("agent_runToagent_run")
  agent_trigger         agent_trigger?         @relation(fields: [trigger_id], references: [id], onUpdate: NoAction)
  agent_run_barrier     agent_run_barrier[]
  agent_run_decision    agent_run_decision[]
  agent_run_event       agent_run_event[]
  agent_run_step        agent_run_step[]
  agent_run_transition  agent_run_transition[]
  agent_tool_run        agent_tool_run[]

  @@index([agent_id])
  @@index([agent_version_id])
  @@index([correlation_id])
  @@index([created_by_id])
  @@index([finished_at])
  @@index([mode])
  @@index([parent_barrier_id])
  @@index([parent_run_id])
  @@index([started_at])
  @@index([status])
  @@index([trace_id])
  @@index([trigger_id])
}

model agent_run_barrier {
  id                      Int                           @id @default(autoincrement())
  run_id                  Int
  kind                    agent_run_barrier_kind_enum
  parallel_group_id       String?                       @db.VarChar(191)
  resume_node_key         String?                       @db.VarChar(127)
  save_to_state_key       String?                       @db.VarChar(127)
  expected_count          Int                           @default(0)
  arrived_count           Int                           @default(0)
  status                  agent_run_barrier_status_enum @default(pending)
  continuation_dispatched Boolean                       @default(false)
  parent_step_id          Int?
  error                   String?
  created_at              DateTime                      @default(now())
  updated_at              DateTime                      @default(now())
  agent_branch_result     agent_branch_result[]
  agent_run_step          agent_run_step?               @relation(fields: [parent_step_id], references: [id], onUpdate: NoAction)
  agent_run               agent_run                     @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@unique([run_id, parallel_group_id], map: "agent_run_barrier_run_group_unique")
  @@index([run_id])
  @@index([status])
}

model agent_run_decision {
  id                                                                Int                          @id @default(autoincrement())
  run_id                                                            Int
  step_id                                                           Int?
  node_id                                                           Int?
  decision_type                                                     agent_run_decision_type_enum
  input_summary                                                     String?
  selected_target_node_id                                           Int?
  selected_edge_id                                                  Int?
  confidence                                                        Decimal?                     @db.Decimal(5, 4)
  reason                                                            String?
  alternatives                                                      Json?
  raw_output                                                        String?
  parsed_output                                                     Json?
  created_at                                                        DateTime                     @default(now())
  agent_node_agent_run_decision_node_idToagent_node                 agent_node?                  @relation("agent_run_decision_node_idToagent_node", fields: [node_id], references: [id], onUpdate: NoAction)
  agent_run                                                         agent_run                    @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_edge                                                        agent_edge?                  @relation(fields: [selected_edge_id], references: [id], onUpdate: NoAction, map: "agent_run_decision_sel_edge_fkey")
  agent_node_agent_run_decision_selected_target_node_idToagent_node agent_node?                  @relation("agent_run_decision_selected_target_node_idToagent_node", fields: [selected_target_node_id], references: [id], onUpdate: NoAction, map: "agent_run_decision_sel_target_fkey")
  agent_run_step                                                    agent_run_step?              @relation(fields: [step_id], references: [id], onUpdate: NoAction)

  @@index([decision_type])
  @@index([node_id])
  @@index([run_id])
  @@index([selected_target_node_id])
  @@index([step_id])
}

model agent_run_event {
  id             Int             @id @default(autoincrement())
  run_id         Int
  step_id        Int?
  node_id        Int?
  event_type     String          @db.VarChar(127)
  event_data     Json?
  sequence       Int             @default(0)
  created_at     DateTime        @default(now())
  agent_node     agent_node?     @relation(fields: [node_id], references: [id], onUpdate: NoAction)
  agent_run      agent_run       @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_run_step agent_run_step? @relation(fields: [step_id], references: [id], onUpdate: NoAction)

  @@index([created_at])
  @@index([event_type])
  @@index([node_id])
  @@index([run_id])
  @@index([run_id, sequence])
  @@index([step_id])
}

model agent_run_step {
  id                   Int                        @id @default(autoincrement())
  run_id               Int
  node_id              Int?
  node_key             String?                    @db.VarChar(127)
  type                 String?                    @db.VarChar(80)
  status               agent_run_step_status_enum @default(pending)
  input                Json?
  output               Json?
  state_before         Json?
  state_after          Json?
  error                String?
  started_at           DateTime?
  finished_at          DateTime?
  duration_ms          Int?
  retry_count          Int                        @default(0)
  sequence             Int                        @default(0)
  parent_step_id       Int?
  branch_id            String?                    @db.VarChar(127)
  parallel_group_id    String?                    @db.VarChar(127)
  created_at           DateTime                   @default(now())
  updated_at           DateTime                   @default(now())
  queue_job_id         Int?
  agent_checkpoint     agent_checkpoint[]
  agent_human_approval agent_human_approval[]
  agent_run_barrier    agent_run_barrier[]
  agent_run_decision   agent_run_decision[]
  agent_run_event      agent_run_event[]
  agent_node           agent_node?                @relation(fields: [node_id], references: [id], onUpdate: NoAction)
  agent_run_step       agent_run_step?            @relation("agent_run_stepToagent_run_step", fields: [parent_step_id], references: [id], onUpdate: NoAction)
  other_agent_run_step agent_run_step[]           @relation("agent_run_stepToagent_run_step")
  agent_run            agent_run                  @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_run_transition agent_run_transition[]
  agent_tool_run       agent_tool_run[]

  @@index([branch_id])
  @@index([finished_at])
  @@index([node_id])
  @@index([parallel_group_id])
  @@index([parent_step_id])
  @@index([queue_job_id])
  @@index([run_id])
  @@index([run_id, sequence])
  @@index([started_at])
  @@index([status])
}

model agent_run_transition {
  id                                                         Int             @id @default(autoincrement())
  run_id                                                     Int
  step_id                                                    Int?
  source_node_id                                             Int?
  target_node_id                                             Int?
  edge_id                                                    Int?
  condition_expression                                       String?
  condition_result                                           Boolean?
  selected                                                   Boolean         @default(false)
  reason                                                     String?
  created_at                                                 DateTime        @default(now())
  agent_edge                                                 agent_edge?     @relation(fields: [edge_id], references: [id], onUpdate: NoAction)
  agent_run                                                  agent_run       @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_node_agent_run_transition_source_node_idToagent_node agent_node?     @relation("agent_run_transition_source_node_idToagent_node", fields: [source_node_id], references: [id], onUpdate: NoAction)
  agent_run_step                                             agent_run_step? @relation(fields: [step_id], references: [id], onUpdate: NoAction)
  agent_node_agent_run_transition_target_node_idToagent_node agent_node?     @relation("agent_run_transition_target_node_idToagent_node", fields: [target_node_id], references: [id], onUpdate: NoAction)

  @@index([edge_id])
  @@index([run_id])
  @@index([selected])
  @@index([source_node_id])
  @@index([step_id])
  @@index([target_node_id])
}

model agent_secret_binding {
  id                     Int                 @id @default(autoincrement())
  agent_id               Int
  agent_version_id       Int?
  node_id                Int?
  integration_profile_id Int
  purpose                String?             @db.VarChar(255)
  created_at             DateTime            @default(now())
  agent                  agent               @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  agent_version          agent_version?      @relation(fields: [agent_version_id], references: [id], onUpdate: NoAction)
  integration_profile    integration_profile @relation(fields: [integration_profile_id], references: [id], onUpdate: NoAction)
  agent_node             agent_node?         @relation(fields: [node_id], references: [id], onUpdate: NoAction)

  @@unique([agent_id, agent_version_id, node_id, integration_profile_id], map: "agent_secret_binding_unique")
  @@index([agent_id])
  @@index([agent_version_id])
  @@index([integration_profile_id])
  @@index([node_id])
}

model agent_tool {
  id                           Int                   @id @default(autoincrement())
  slug                         String                @unique(map: "agent_tool_slug_unique") @db.VarChar(255)
  name                         String                @db.VarChar(180)
  description                  String?
  type                         agent_tool_type_enum
  module                       String?               @db.VarChar(127)
  action                       String?               @db.VarChar(127)
  input_schema                 Json?
  output_schema                Json?
  config_schema                Json?
  requires_integration_profile Boolean               @default(false)
  is_dangerous                 Boolean               @default(false)
  is_active                    Boolean               @default(true)
  created_at                   DateTime              @default(now())
  updated_at                   DateTime              @default(now())
  integration_type_id          Int?
  integration_provider_id      Int?
  integration_provider         integration_provider? @relation(fields: [integration_provider_id], references: [id], onUpdate: NoAction)
  integration_type             integration_type?     @relation(fields: [integration_type_id], references: [id], onUpdate: NoAction)
  agent_tool_run               agent_tool_run[]

  @@index([is_active])
  @@index([module])
  @@index([type])
  @@index([integration_provider_id], map: "idx_agent_tool_integration_provider_id")
  @@index([integration_type_id], map: "idx_agent_tool_integration_type_id")
}

model agent_tool_run {
  id                     Int                        @id @default(autoincrement())
  run_id                 Int
  step_id                Int?
  tool_id                Int?
  integration_profile_id Int?
  provider               String?                    @db.VarChar(80)
  model                  String?                    @db.VarChar(127)
  status                 agent_tool_run_status_enum @default(pending)
  input                  Json?
  output                 Json?
  error                  String?
  http_status_code       Int?
  started_at             DateTime?
  finished_at            DateTime?
  duration_ms            Int?
  retry_count            Int                        @default(0)
  input_tokens           Int                        @default(0)
  output_tokens          Int                        @default(0)
  total_tokens           Int                        @default(0)
  cached_tokens          Int                        @default(0)
  reasoning_tokens       Int                        @default(0)
  audio_tokens           Int                        @default(0)
  image_tokens           Int                        @default(0)
  unit_price_input       Decimal?                   @db.Decimal(10, 6)
  unit_price_output      Decimal?                   @db.Decimal(10, 6)
  estimated_cost         Decimal?                   @db.Decimal(12, 6)
  actual_cost            Decimal?                   @db.Decimal(12, 6)
  currency               String                     @default("USD") @db.Char(3)
  created_at             DateTime                   @default(now())
  updated_at             DateTime                   @default(now())
  integration_profile    integration_profile?       @relation(fields: [integration_profile_id], references: [id], onUpdate: NoAction)
  agent_run              agent_run                  @relation(fields: [run_id], references: [id], onDelete: Cascade)
  agent_run_step         agent_run_step?            @relation(fields: [step_id], references: [id], onUpdate: NoAction)
  agent_tool             agent_tool?                @relation(fields: [tool_id], references: [id], onUpdate: NoAction)

  @@index([finished_at])
  @@index([integration_profile_id])
  @@index([provider, model])
  @@index([run_id])
  @@index([started_at])
  @@index([status])
  @@index([step_id])
  @@index([tool_id])
}

model agent_trigger {
  id                     Int                     @id @default(autoincrement())
  agent_id               Int
  agent_version_id       Int?
  type                   agent_trigger_type_enum @default(manual)
  name                   String                  @db.VarChar(180)
  config                 Json?
  is_active              Boolean                 @default(true)
  webhook_integration_id Int?
  cron_expression        String?                 @db.VarChar(127)
  created_by_id          Int?
  created_at             DateTime                @default(now())
  updated_at             DateTime                @default(now())
  agent_run              agent_run[]
  agent                  agent                   @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  agent_version          agent_version?          @relation(fields: [agent_version_id], references: [id], onUpdate: NoAction)
  user                   user?                   @relation(fields: [created_by_id], references: [id])
  webhook_integration    webhook_integration?    @relation(fields: [webhook_integration_id], references: [id], onUpdate: NoAction)

  @@index([agent_id])
  @@index([agent_version_id])
  @@index([is_active])
  @@index([type])
  @@index([webhook_integration_id])
}

model agent_variable {
  id          Int                      @id @default(autoincrement())
  agent_id    Int?
  key         String                   @db.VarChar(127)
  value       String?
  type        agent_variable_type_enum @default(string)
