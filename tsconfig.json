      "@hed-hog/api-pagination/*": ["packages/api-pagination/src/*"],
      "@hed-hog/api-prisma": ["packages/api-prisma/src"],
      "@hed-hog/api-prisma/*": ["packages/api-prisma/src/*"],
      "@hed-hog/next-app-provider": ["packages/next-app-provider/src"],
      "@hed-hog/next-app-provider/*": ["packages/next-app-provider/src/*"],
      "@hed-hog/api-types": ["packages/api-types/src"],
